{
  "name": "letstry-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "codegen": "graphql-codegen --config codegen.ts",
    "dev:ngrok": "bash scripts/start-with-ngrok.sh",
    "build:apk": "cd android && ./gradlew clean assembleRelease && cp app/build/outputs/apk/release/app-release.apk ../../../letstry-mobile-release.apk && echo '✅ APK ready at root: letstry-mobile-release.apk'"
  },
  "dependencies": {
