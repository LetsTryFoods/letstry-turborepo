{
  "expo": {
    "name": "letstry-mobile",
    "slug": "letstry-mobile",
    "version": "3.3.0",
    "orientation": "portrait",
    "scheme": "letstry-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.letstryfoods",
      "buildNumber": "210",
      "icon": "./assets/icon.png",
      "googleServicesFile": "./ios/GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.letstryapp",
      "versionCode": 209,
      "googleServicesFile": "./android/app/google-services.json",
      "permissions": [
        "com.google.android.gms.permission.AD_ID"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyA44Ri5mmnDX-wE8folHq69LjEy1u8NLF0"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-foreground.png",
        "backgroundColor": "#FFFBEB"
      }
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/app"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "graphqlUrl": "https://apiv3.letstryfoods.com/graphql",
      "router": {},
      "eas": {
        "projectId": "b4a3a21a-6e97-4eef-8285-801285342be7"
      }
    }
  }
}
